---
const year = new Date().getFullYear();
const homeHref = import.meta.env.BASE_URL;
const logoSrc = `${import.meta.env.BASE_URL}assets/gepac-logo.webp`.replace('/BlogGepacV2assets/', '/BlogGepacV2/assets/');
---
<footer class="site-footer">
  <div class="container">

    <div class="footer-grid">
      <div class="footer-brand">
        <img class="footer-logo" src={logoSrc} alt="Logo GEPAC" />
        <p class="footer-tag">Grupo Español de Pacientes con Cáncer. Información de salud para pacientes y familiares.</p>
      </div>

      <div class="footer-col">
        <h4>Navegación</h4>
        <a href={homeHref}>Portada</a>
        <a href={`${homeHref}archivo/`}>Archivo</a>
        <a href={`${homeHref}relatos/`}>Relatos</a>
        <a href={`${homeHref}buscar/`}>Buscar</a>
      </div>

      <div class="footer-col">
        <h4>Enlaces</h4>
        <a href="https://www.gepac.es" target="_blank" rel="noopener">Web</a>
        <a href="https://x.com/GEPAC_" target="_blank" rel="noopener">X</a>
        <a href="https://www.facebook.com/Tengocancer" target="_blank" rel="noopener">Facebook</a>
        <a href="https://www.instagram.com/gepac_cancer/?hl=es" target="_blank" rel="noopener">Instagram</a>
        <a href="https://es.linkedin.com/company/gepac-grupo-espa%C3%B1ol-de-pacientes-con-cancer" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} GEPAC · Todos los derechos reservados</span>
      <span class="footer-krokland">Sistema editorial por <a href="https://krokland.com" target="_blank" rel="noopener">Krokland</a></span>
    </div>

  </div>
</footer>
