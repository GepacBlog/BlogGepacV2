---
const year = new Date().getFullYear();
const logoSrc = `${import.meta.env.BASE_URL}assets/gepac-logo.webp`;
---
<footer class="site-footer">
  <div class="container">

    <div class="footer-grid">
      <div class="footer-brand">
        <img class="footer-logo" src={logoSrc} alt="Logo GEPAC" />
        <p class="footer-tag">Grupo Español de Pacientes con Cáncer. Información de salud para pacientes y familiares.</p>
      </div>

      <div class="footer-col">
        <h4>Navegación</h4>
        <a href="/">Portada</a>
        <a href="/archivo">Archivo</a>
        <a href="/relatos">Relatos</a>
        <a href="/buscar">Buscar</a>
      </div>

      <div class="footer-col">
        <h4>Enlaces</h4>
        <a href="https://www.gepac.es" target="_blank" rel="noopener">gepac.es</a>
        <a href="/rss.xml">RSS</a>
        <a href="mailto:info@gepac.es">info@gepac.es</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} GEPAC · Todos los derechos reservados</span>
      <span class="footer-krokland">Sistema editorial por <a href="https://krokland.com" target="_blank" rel="noopener">Krokland</a></span>
    </div>

  </div>
</footer>
