---
import { categoriaLabel, formatFechaCorta } from '../lib/utils.js';

export interface Props {
  articulo: any;
}
const { articulo } = Astro.props;
const { data, slug } = articulo;
const baseHref = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const url = `${baseHref}articulo/${slug}/`;
const imgUrl = data.imagen?.url ?? null;
const imageFit = data.layout_imagen === 'contain' ? 'contain' : 'cover';
---
<article class="article-row">
  <div class="article-meta">
    <time class="article-date" datetime={data.fecha.toISOString()}>{formatFechaCorta(data.fecha)}</time>
    <span class="article-cat">{categoriaLabel(data.categoria)}</span>
  </div>

  <div class="article-body">
    <h2 class="article-title">
      <a href={url}>{data.titulo}</a>
    </h2>
    <p class="article-summary">{data.resumen}</p>
    <p class="article-read-more">
      <a href={url}>Leer más…</a>
    </p>
    {data.tags && data.tags.length > 0 && (
      <div class="article-tags">
        {data.tags.slice(0, 4).map(t => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>

  <a href={url} class="article-image" aria-hidden="true" tabindex="-1" data-fit={imageFit}>
    {imgUrl ? (
      <img src={imgUrl} alt="" loading="lazy" />
    ) : (
      <span class="article-image-empty">GEPAC</span>
    )}
  </a>
</article>
